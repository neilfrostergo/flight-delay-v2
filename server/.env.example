# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgres://flightdelay:flightdelay@localhost:5432/flightdelay

# ── Security ──────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=

# ── Server ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Multi-tenancy ──────────────────────────────────────────────
# Subdomains are resolved as: {slug}.{BASE_DOMAIN}
# e.g. BASE_DOMAIN=platform.co.uk → ergo.platform.co.uk resolves to slug "ergo"
BASE_DOMAIN=localhost

# Dev only: fallback tenant slug when no subdomain matches (X-Tenant-Slug header also works)
DEV_TENANT_SLUG=demo

# ── Admin Portal ───────────────────────────────────────────────
# CORS origin for admin SPA (in production, set to your admin domain)
ADMIN_CORS_ORIGIN=http://localhost:3000

# Password for the superadmin account created on first run
ADMIN_SEED_PASSWORD=changeme

# ── Email (SMTP) ───────────────────────────────────────────────
# Use Mailtrap for development: https://mailtrap.io
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=

# ── Azure Event Hub (production only) ──────────────────────────
# Create via Azure Portal → Event Hubs → Standard tier
# Give OAG the Send connection string; use Listen string here
EVENT_HUB_CONNECTION_STRING=
EVENT_HUB_NAME=oag-flight-alerts

# Azure Blob Storage — used for consumer checkpointing
EVENT_HUB_STORAGE_CONNECTION_STRING=
EVENT_HUB_STORAGE_CONTAINER=event-hub-checkpoints
