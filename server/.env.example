# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgres://flightdelay:flightdelay@localhost:5432/flightdelay

# ── Security ──────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=

# ── Server ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Multi-tenancy ──────────────────────────────────────────────
# Subdomains are resolved as: {slug}.{BASE_DOMAIN}
# e.g. BASE_DOMAIN=platform.co.uk → ergo.platform.co.uk resolves to slug "ergo"
BASE_DOMAIN=localhost

# Dev only: fallback tenant slug when no subdomain matches (X-Tenant-Slug header also works)
DEV_TENANT_SLUG=demo

# ── Admin Portal ───────────────────────────────────────────────
# CORS origin for admin SPA (in production, set to your admin domain)
ADMIN_CORS_ORIGIN=http://localhost:3000

# Password for the superadmin account created on first run
ADMIN_SEED_PASSWORD=changeme

# ── Email ──────────────────────────────────────────────────────
# Dev email override — all outbound email goes here instead of the real recipient.
# Leave blank in UAT/production.
DEV_EMAIL_OVERRIDE=neil@frostie.co.uk

# Azure Communication Services (UAT + Production)
# When ACS_CONNECTION_STRING is set, ACS is used instead of SMTP.
# Leave blank in local development to use SMTP/Mailtrap below.
ACS_CONNECTION_STRING=

# SMTP — local development fallback (Mailtrap sandbox)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=

# ── Snowflake (reference data sync) ───────────────────────────
# Run: npm run sync:refdata  (once for dev, monthly cron in production)
SNOWFLAKE_ACCOUNT=oagnavigation-ergotravel
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=DIRECT_CUSTOMER_CONFIGURATIONS

# ── Azure Blob Storage (UAT + production) ─────────────────────
# Uses managed identity — no connection string needed. Leave blank in local dev.
BLOB_STORAGE_ACCOUNT=fdv2prodsa
BLOB_STORAGE_CONTAINER=claim-documents

# ── Azure OpenAI (UAT + production) ───────────────────────────
# Uses managed identity — no API key needed. Leave blank in local dev to skip AI verification.
AZURE_OPENAI_ENDPOINT=https://oai-ergo-corp-uks.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini-prd
AZURE_OPENAI_VISION_DEPLOYMENT=gpt4o-prd
# AZURE_CLIENT_ID is set automatically by the Container App managed identity binding

# ── Azure Event Hub (production only) ──────────────────────────
# Create via Azure Portal → Event Hubs → Standard tier
# Give OAG the Send connection string; use Listen string here
EVENT_HUB_CONNECTION_STRING=
EVENT_HUB_NAME=oag-flight-alerts

# Azure Blob Storage — used for consumer checkpointing
EVENT_HUB_STORAGE_CONNECTION_STRING=
EVENT_HUB_STORAGE_CONTAINER=event-hub-checkpoints
